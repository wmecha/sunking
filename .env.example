# Sun King Location Intelligence — Environment Variables
# Copy this file to .env.local and fill in your values

# App password for internal login gate
# Any email @sunking.com or @wallacemecha.com + this password = access
# TODO: Replace with proper auth (NextAuth/Clerk) before production
SUN_KING_APP_PASSWORD=4411

# Session signing secret — change this to a random string in production
SESSION_SECRET=change-this-to-a-random-secret-in-production

# Supabase PostgreSQL — Transaction Pooler URL (port 6543) for serverless
# Format: postgresql://postgres.<ref>:<password>@aws-X-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Supabase Storage (photo uploads)
SUPABASE_URL=https://bzpeyrhkfjbdjojkaetr.supabase.co
# Service-role / secret key — bypasses RLS for server-side uploads. KEEP SECRET.
# Get from: Supabase Dashboard → Project Settings → API Keys → secret key
SUPABASE_SERVICE_KEY=

# Google Sheets sync (Composio)
# Options: disabled, google_service_account, composio.
SHEET_SYNC_PROVIDER=google_service_account
# Master Tracker spreadsheet ID — leave empty to disable sync
GOOGLE_SHEET_ID=1DGAHE9zJ3Dy2VVgs_Jx9lMKYeW4Ox8FLSK7nRgJzWVY
# Sheet tab name within the spreadsheet
GOOGLE_SHEET_TAB=Master Tracker

# Preferred: paste the complete service account JSON from Google Cloud into
# Vercel as a single secret value. Do not commit the JSON file.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Alternative split form if your host does not support large JSON env vars.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Legacy fallback provider: SHEET_SYNC_PROVIDER=composio
# Composio API key (server-side) — get from Composio dashboard → API keys
COMPOSIO_API_KEY=
# user_id that owns the Google Sheets connection in Composio
# (typically your login email, e.g. admin@wallacemecha.com)
COMPOSIO_USER_ID=admin@wallacemecha.com
# Optional but recommended for production: the exact active Google Sheets
# connected account ID from Composio. This avoids user/entity mismatches.
COMPOSIO_CONNECTED_ACCOUNT_ID=
